<Window
    x:Class="ReportingFixedDocument.A4HochFixedDokument"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="A4HochFixedDokument"
    Width="1200"
    Height="600"
    Loaded="OnLoaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <DocumentViewer
            x:Name="rootDoc"
            Grid.Row="1"
            ContextMenu="{x:Null}"
            Style="{DynamicResource ResourceKey=DocumentViewerStyle}">

            <DocumentViewer.CommandBindings>
                <CommandBinding Command="ApplicationCommands.Print" Executed="OnPrint" />
                <CommandBinding Command="ApplicationCommands.Open" Executed="CommandBindingOnOpen" />
                <CommandBinding CanExecute="CommandBindingCanOnOpen" Command="ApplicationCommands.Open" />
                <CommandBinding Command="ApplicationCommands.Save" Executed="CommandBindingOnSave" />
                <CommandBinding CanExecute="CommandBindingCanExecuteOnSave" Command="ApplicationCommands.Save" />
            </DocumentViewer.CommandBindings>

            <DocumentViewer.Resources>
                <Style TargetType="ContentControl">
                    <Style.Triggers>
                        <Trigger Property="Name" Value="PART_FindToolBarHost">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </Style.Triggers>
                </Style>

                <Style x:Key="DocumentViewerStyle" TargetType="DocumentViewer">
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" />
                    <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" />
                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DocumentViewer">
                                <Grid KeyboardNavigation.TabNavigation="Local">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <ToolBar KeyboardNavigation.TabNavigation="Continue" ToolBarTray.IsLocked="True">
                                        <Button Command="ApplicationCommands.Print" CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}">
                                            <Button.Content>
                                                <Grid>
                                                    <Path
                                                        Width="22"
                                                        Height="22"
                                                        Data="M18,3H6V7H18M19,12A1,1 0 0,1 18,11A1,1 0 0,1 19,10A1,1 0 0,1 20,11A1,1 0 0,1 19,12M16,19H8V14H16M19,8H5A3,3 0 0,0 2,11V17H6V21H18V17H22V11A3,3 0 0,0 19,8Z"
                                                        Fill="Black"
                                                        Stretch="Uniform" />
                                                </Grid>
                                            </Button.Content>
                                        </Button>

                                        <Separator />

                                        <Button Command="NavigationCommands.IncreaseZoom" CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}">
                                            <Button.Content>
                                                <Grid>
                                                    <Path
                                                        Width="22"
                                                        Height="22"
                                                        Data="M15.5,14L20.5,19L19,20.5L14,15.5V14.71L13.73,14.43C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.43,13.73L14.71,14H15.5M9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14M12,10H10V12H9V10H7V9H9V7H10V9H12V10Z"
                                                        Fill="Black"
                                                        Stretch="Uniform" />
                                                </Grid>
                                            </Button.Content>
                                        </Button>

                                        <Button Command="NavigationCommands.DecreaseZoom" CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}">
                                            <Button.Content>
                                                <Grid>
                                                    <Path
                                                        Width="22"
                                                        Height="22"
                                                        Data="M15.5,14H14.71L14.43,13.73C15.41,12.59 16,11.11 16,9.5A6.5,6.5 0 0,0 9.5,3A6.5,6.5 0 0,0 3,9.5A6.5,6.5 0 0,0 9.5,16C11.11,16 12.59,15.41 13.73,14.43L14,14.71V15.5L19,20.5L20.5,19L15.5,14M9.5,14C7,14 5,12 5,9.5C5,7 7,5 9.5,5C12,5 14,7 14,9.5C14,12 12,14 9.5,14M7,9H12V10H7V9Z"
                                                        Fill="Black"
                                                        Stretch="Uniform" />
                                                </Grid>
                                            </Button.Content>
                                        </Button>

                                        <Separator />

                                        <Button
                                            Command="NavigationCommands.Zoom"
                                            CommandParameter="100.0"
                                            CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}">
                                            <Button.Content>
                                                <Grid>
                                                    <Path
                                                        Width="22"
                                                        Height="22"
                                                        Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z"
                                                        Fill="Black"
                                                        Stretch="Uniform" />
                                                </Grid>
                                            </Button.Content>
                                        </Button>
                                        <Button Command="DocumentViewer.FitToWidthCommand" CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}">
                                            <Button.Content>
                                                <Grid>
                                                    <Path
                                                        Width="22"
                                                        Height="22"
                                                        Data="M20,2H4C2.89,2 2,2.89 2,4V20C2,21.11 2.89,22 4,22H20C21.11,22 22,21.11 22,20V4C22,2.89 21.11,2 20,2M20,20H4V4H20M13,8V10H11V8H9L12,5L15,8M16,15V13H14V11H16V9L19,12M10,13H8V15L5,12L8,9V11H10M15,16L12,19L9,16H11V14H13V16"
                                                        Fill="Black"
                                                        Stretch="Uniform" />
                                                </Grid>
                                            </Button.Content>
                                        </Button>


                                        <Button
                                            Command="DocumentViewer.FitToMaxPagesAcrossCommand"
                                            CommandParameter="1"
                                            CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}">
                                            <Button.Content>
                                                <Grid>
                                                    <Path
                                                        Width="22"
                                                        Height="22"
                                                        Data="M19,19H5V5H19M19,3H5A2,2 0 0,0 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5A2,2 0 0,0 19,3M12,17H14V7H10V9H12"
                                                        Fill="Black"
                                                        Stretch="Uniform" />
                                                </Grid>
                                            </Button.Content>
                                        </Button>

                                        <Button
                                            Command="DocumentViewer.FitToMaxPagesAcrossCommand"
                                            CommandParameter="2"
                                            CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}">
                                            <Button.Content>
                                                <Grid>
                                                    <Path
                                                        Width="22"
                                                        Height="22"
                                                        Data="M17,13H13V11H15A2,2 0 0,0 17,9V7C17,5.89 16.1,5 15,5H11V7H15V9H13A2,2 0 0,0 11,11V15H17M21,17H7V3H21M21,1H7A2,2 0 0,0 5,3V17A2,2 0 0,0 7,19H21A2,2 0 0,0 23,17V3A2,2 0 0,0 21,1M3,5H1V21A2,2 0 0,0 3,23H19V21H3V5Z"
                                                        Fill="Black"
                                                        Stretch="Uniform" />
                                                </Grid>
                                            </Button.Content>
                                        </Button>

                                        <Separator />

                                        <Button Command="ApplicationCommands.Open">
                                            <Button.Content>
                                                <Grid>
                                                    <Path
                                                        Width="22"
                                                        Height="22"
                                                        Data="M22,3H5A2,2 0 0,0 3,5V9H5V5H22V19H5V15H3V19A2,2 0 0,0 5,21H22A2,2 0 0,0 24,19V5A2,2 0 0,0 22,3M7,15V13H0V11H7V9L11,12L7,15M20,13H13V11H20V13M20,9H13V7H20V9M17,17H13V15H17V17Z"
                                                        Fill="Black"
                                                        Stretch="Uniform" />
                                                </Grid>
                                            </Button.Content>
                                        </Button>

                                        <Button Command="ApplicationCommands.Save">
                                            <Button.Content>
                                                <Grid>
                                                    <Path
                                                        Width="22"
                                                        Height="22"
                                                        Data="M17 3H5C3.89 3 3 3.9 3 5V19C3 20.1 3.89 21 5 21H19C20.1 21 21 20.1 21 19V7L17 3M19 19H5V5H16.17L19 7.83V19M12 12C10.34 12 9 13.34 9 15S10.34 18 12 18 15 16.66 15 15 13.66 12 12 12M6 6H15V10H6V6Z"
                                                        Fill="Black"
                                                        Stretch="Uniform" />
                                                </Grid>
                                            </Button.Content>
                                        </Button>
                                    </ToolBar>

                                    <ScrollViewer
                                        x:Name="PART_ContentHost"
                                        Grid.Row="1"
                                        CanContentScroll="true"
                                        HorizontalScrollBarVisibility="Auto"
                                        IsTabStop="true" />

                                    <ContentControl x:Name="PART_FindToolBarHost" Grid.Row="2" />
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DocumentViewer.Resources>

            <FixedDocument x:Name="docB" />

        </DocumentViewer>
    </Grid>
</Window>
